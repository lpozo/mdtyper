{
  "name": "youtype",
  "displayName": "YouType",
  "description": "Typora-like WYSIWYG Markdown editor for VS Code",
  "version": "0.0.1",
  "publisher": "youtype",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "youtype.markdownEditor",
        "displayName": "YouType WYSIWYG Editor",
        "selector": [
          {
            "filenamePattern": "*.md"
          }
        ],
        "priority": "default"
      }
    ],
    "commands": [
      {
        "command": "youtype.openAsText",
        "title": "YouType: Reopen as Text Editor"
      }
    ]
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "vscode:prepublish": "node esbuild.mjs --production",
    "lint": "tsc --noEmit && tsc --noEmit -p tsconfig.webview.json"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.3.0",
    "@types/vscode": "^1.109.0",
    "esbuild": "^0.27.3",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@milkdown/kit": "^7.18.0",
    "@milkdown/theme-nord": "^7.18.0"
  }
}
