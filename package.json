{
  "name": "mdtyper",
  "displayName": "MdTyper",
  "description": "Typora-like WYSIWYG Markdown editor for VS Code",
  "version": "0.0.1",
  "publisher": "mdtyper",
  "author": {
    "name": ""
  },
  "repository": {
    "type": "git",
    "url": ""
  },
  "bugs": {
    "url": ""
  },
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#2e3440",
    "theme": "dark"
  },
  "pricing": "Free",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": ["markdown", "wysiwyg", "editor", "typora", "milkdown"],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "mdtyper.markdownEditor",
        "displayName": "MdTyper WYSIWYG Editor",
        "selector": [
          {
            "filenamePattern": "*.md"
          }
        ],
        "priority": "default"
      }
    ],
    "commands": [
      {
        "command": "mdtyper.openAsText",
        "title": "MdTyper: Reopen as Text Editor"
      }
    ]
  },
  "scripts": {
    "build": "node scripts/esbuild.mjs",
    "watch": "node scripts/esbuild.mjs --watch",
    "vscode:prepublish": "node scripts/esbuild.mjs --production",
    "package": "vsce package",
    "lint": "tsc --noEmit && tsc --noEmit -p webview-src/tsconfig.json && eslint src webview-src",
    "format": "prettier --write src webview-src",
    "format:check": "prettier --check src webview-src"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.3.0",
    "@types/vscode": "^1.109.0",
    "@types/vscode-webview": "^1.57.5",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.27.3",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@milkdown/kit": "^7.18.0",
    "@milkdown/theme-nord": "^7.18.0"
  }
}
